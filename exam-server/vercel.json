{
  "rewrites": [
    { "source": "/", "destination": "/主播合规考试.html" },
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/admin", "destination": "/api" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    }
  ]
}
